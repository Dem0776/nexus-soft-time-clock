# =====================================================================
# Config para scripts/redeploy.sh — Nexus Soft Time Clock
# Copia a scripts/.env y rellena. scripts/.env está en .gitignore: NO subir.
#   cp scripts/.env.example scripts/.env
# =====================================================================

# --- Portainer ---
PORTAINER_URL=https://85.239.240.43:9443
PORTAINER_USER=Admon_dev
PORTAINER_PASS=              # contraseña de Portainer  (obligatorio)
STACK_ID=72
ENDPOINT_ID=2

# --- Repositorio git privado (para que Portainer lo clone) ---
GH_USER=Dem0776
GH_PAT=                      # Personal Access Token de GitHub  (obligatorio)
GIT_REF=refs/heads/main

# --- Secretos del stack (deben COINCIDIR con los ya desplegados) ---
DB_PASSWORD=                 # (obligatorio)  ver Stack → Environment variables en Portainer
SECURITY_QR_SECRET=          # (obligatorio)

# --- Parámetros de la app ---
DB_NAME=nexus
DB_USER=nexus
HTTP_PORT=8088
SPRING_PROFILES_ACTIVE=prod
LOG_LEVEL_APP=INFO

# --- Verificación post-deploy ---
APP_URL=http://85.239.240.43:8088
VERIFY_EMAIL=admin@demo.com
VERIFY_PASSWORD=Admin123!

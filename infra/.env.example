# Copia a infra/.env y ajusta. NO subir .env con secretos reales al repositorio.

# --- Base de datos ---
DB_NAME=nexus
DB_USER=nexus
DB_PASSWORD=nexus

# --- MinIO (evidencias) ---
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# --- Grafana ---
GRAFANA_PASSWORD=admin

# --- Backend (perfil dev usa estos por defecto) ---
SERVER_PORT=8080
LOG_LEVEL_APP=DEBUG

# --- Seguridad (se completan en Iteración 5) ---
# JWT_KEYSTORE=...
# JWT_ACCESS_TTL_SECONDS=900
# JWT_REFRESH_TTL_DAYS=30
